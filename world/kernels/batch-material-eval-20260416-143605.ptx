.version 8.5
.target sm_87
.address_size 64
.visible .entry batch_material_eval(.param .u64 boards_ptr, .param .u64 scores_ptr)
.maxntid 512, 1, 1
{
    .reg .u32 %r<8>;
    .reg .b64 %rd<6>;
    .reg .pred %p<3>;
    mov.u32 %r1, %tid.x;
    setp.ge.u32 %p1, %r1, 512;
    @%p1 bra DONE;
    shr.u32 %r2, %r1, 6;
    and.b32 %r3, %r1, 63;
    ld.param.u64 %rd1, [boards_ptr];
    mul.wide.u32 %rd2, %r1, 4;
    add.u64 %rd3, %rd1, %rd2;
    ld.global.u32 %r4, [%rd3];
    ld.param.u64 %rd4, [scores_ptr];
    mul.wide.u32 %rd5, %r2, 4;
    add.u64 %rd5, %rd4, %rd5;
    atom.global.add.u32 %r5, [%rd5], %r4;
    DONE:
    ret;
}
